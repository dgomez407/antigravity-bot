# ====================================================================
# LAZYGRAVITY ORCHESTRATION CONTEXT - DISCORD SERVER ARCHITECTURE
# ====================================================================

# Active Platform Target
PLATFORMS=discord

# Paste your Discord Bot Token from the Developer Portal
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Your Specific Target Server (Guild) ID where the bot lives
# (Right-click your server icon in Discord and click "Copy Server ID")
DISCORD_GUILD_ID="your_guild_id_here"
CLIENT_ID="your_client_id_here"

# NIST Zero Trust Access List: Your personal numerical Discord User ID
# (Right-click your profile picture and click "Copy User ID")
ALLOWED_USER_IDS="your_discord_user_id_here"

# Local Communication
DEBUGGING_PORT=9222
ANTIGRAVITY_EXE="/c/Users/your_username/AppData/Local/Programs/Antigravity IDE/Antigravity IDE.exe"
WORKSPACE_DIRECTORY="C:\Users\your_username\your_workspace_directory"
